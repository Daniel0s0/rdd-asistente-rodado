# RDD: Asistente Rodado - Environment Variables
# Copy to .env and fill in your actual values
# NEVER commit .env to git (only .env.example)

# ═══════════════════════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════
# INTEGRACIÓN SaaS (legal-journey-saas)
# ═══════════════════════════════════════════════════════════

# Secret compartido para validar firmas de webhook del SaaS
# Debe ser igual a SAAS_WEBHOOK_SECRET en el SaaS
SAAS_WEBHOOK_SECRET=your_webhook_secret_here_keep_secure

# URL del SaaS (para comunicación interna, si está en mismo VPS)
SAAS_API_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# SEGURIDAD - UI Layer
# ═══════════════════════════════════════════════════════════

# API Key para autenticar requests desde UI (Dashboard, Chat)
# Genera: openssl rand -base64 32
UI_API_KEY=your_api_key_min_32_chars_here

# Dominios permitidos para CORS (CSV)
# Ejemplo: http://localhost:3000,https://dashboard.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# GOOGLE WORKSPACE - Service Account
# ═══════════════════════════════════════════════════════════

# Email del service account (formato: xxx@xxx.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=rdd@your-project.iam.gserviceaccount.com

# JSON key de service account (base64 encoded)
# Pasos:
# 1. Ve a Google Cloud Console → Service Accounts
# 2. Crea o selecciona service account
# 3. Crea JSON key
# 4. Ejecuta: cat key.json | base64
# 5. Pega aquí (sin saltos de línea)
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=your_base64_encoded_json_key_here

# ID del Google Sheet INGRESOS_CAUSAS
# Ejemplo: 1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
GOOGLE_SHEETS_SPREADSHEET_ID=your_sheet_id_here

# ID de la carpeta raíz en Google Drive (donde están todos los clientes)
# Ejemplo: 1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_root_folder_id_here

# ═══════════════════════════════════════════════════════════
# CLAUDE AI (Anthropic)
# ═══════════════════════════════════════════════════════════

# API key de Anthropic (formato: sk-ant-...)
# Ve a https://console.anthropic.com para obtener tu key
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# Modelo Claude a usar (recomendado: claude-3-5-sonnet-20241022)
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS (Historial de Conversaciones)
# ═══════════════════════════════════════════════════════════

# Tipo de BD: 'sqlite' o 'postgres'
DATABASE_TYPE=sqlite

# Para SQLite (simple, local)
DATABASE_PATH=./data/rdd.db

# Para PostgreSQL (robusto, producción)
# DATABASE_URL=postgresql://user:password@localhost:5432/rdd_db

# ═══════════════════════════════════════════════════════════
# MONITOREO (Opcional)
# ═══════════════════════════════════════════════════════════

# Sentry DSN para error tracking
# Deja vacío si no usas Sentry
SENTRY_DSN=

# Environment tag para Sentry (production, staging, development)
SENTRY_ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════
# LIMITES Y CONFIGURACIÓN
# ═══════════════════════════════════════════════════════════

# Rate limit: máximo número de webhooks por minuto
WEBHOOK_RATE_LIMIT=100

# Rate limit: máximo número de chat messages por minuto
CHAT_RATE_LIMIT=30

# Timeout para Google API calls (en ms)
GOOGLE_API_TIMEOUT=30000

# Máximo número de intentos para retry en Google APIs
GOOGLE_API_MAX_RETRIES=3

# ═══════════════════════════════════════════════════════════
# CONFIGURACIÓN DE AGENT
# ═══════════════════════════════════════════════════════════

# Máximo número de turn previos a incluir en contexto de Claude
CLAUDE_MAX_CONTEXT_TURNS=10

# Temperatura para Claude (0.0 = determinístico, 1.0 = creativo)
# Recomendado: 0.3 para consistencia en registros financieros
CLAUDE_TEMPERATURE=0.3

# ═══════════════════════════════════════════════════════════
# AUDITORÍA Y SEGURIDAD
# ═══════════════════════════════════════════════════════════

# Habilitar audit logging (registra todos los cambios en Sheets)
ENABLE_AUDIT_LOGGING=true

# Habilitar logging detallado (puede ser verbose)
ENABLE_DETAILED_LOGGING=false

# Archivos sensibles que no loguear (para evitar leaks)
SENSITIVE_FIELDS=GOOGLE_SERVICE_ACCOUNT_KEY_BASE64,ANTHROPIC_API_KEY,SAAS_WEBHOOK_SECRET

# ═══════════════════════════════════════════════════════════
# NOTAS PARA SETUP
# ═══════════════════════════════════════════════════════════

# 1. Google Service Account Setup:
#    - Ve a Google Cloud Console
#    - Crea Service Account para RDD
#    - Dale permisos:
#      * Google Sheets: Editor
#      * Google Drive: Editor
#    - Descarga JSON key
#    - Base64 encode y pega arriba

# 2. Google Sheets Setup:
#    - Crea Sheet "INGRESOS_CAUSAS"
#    - Comparte con email del service account (Editor)
#    - Copia ID del Sheet (de la URL)

# 3. Google Drive Setup:
#    - Crea folder raíz "INGRESOS_CAUSAS" en Drive
#    - Comparte con email del service account (Editor)
#    - Copia ID del folder (de la URL)

# 4. Anthropic API:
#    - Ve a https://console.anthropic.com
#    - Crea/copia API key
#    - Asegúrate que tenga créditos suficientes

# 5. VPS Setup:
#    - SSH a tu VPS
#    - npm install
#    - Crea .env (copia .env.example)
#    - Rellena variables arriba
#    - npm run build
#    - pm2 start ecosystem.config.js
