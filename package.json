{
  "name": "rdd-asistente-rodado",
  "version": "0.1.0",
  "description": "Agente conversacional autónomo para registro contable de causas legales",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "pm2:start": "pm2 start deployment/pm2.config.js",
    "pm2:stop": "pm2 stop rdd",
    "pm2:logs": "pm2 logs rdd"
  },
  "keywords": [
    "rdd",
    "asistente",
    "contable",
    "causas",
    "claude",
    "ai"
  ],
  "author": "Daniel Fuentes",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.23.0",
    "googleapis": "^118.0.0",
    "google-auth-library": "^8.8.0",
    "express": "^4.18.2",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "p-queue": "^7.3.4",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.15.1",
    "typescript": "^5.4.5",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "pm2": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
